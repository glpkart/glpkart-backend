generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum EligibilityResult {
  ELIGIBLE
  INELIGIBLE
}

// FIXED: was BOOKED — backend uses SCHEDULED
enum ConsultStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum DoseDecision {
  CONTINUE
  STEP_UP
  REDUCE
  STOP
}

enum OrderStatus {
  PENDING
  PAID
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum InjectionSite {
  LEFT_ABDOMEN
  RIGHT_ABDOMEN
  LEFT_THIGH
  RIGHT_THIGH
}

enum ForumTopic {
  SIDE_EFFECTS
  FOOD_AND_EATING
  SUCCESS_STORIES
  DOSING_QUESTIONS
  MENTAL_HEALTH
  DOCTOR_ADVICE
  OTHER
}

enum ModerationStatus {
  VISIBLE
  FLAGGED
  REMOVED
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  IN_APP
}

enum NotificationStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

// ─── OTP ───────────────────────────────────────────────────────────────────────
// ADDED: was missing from schema — backend calls prisma.oTPSession.upsert()

model OtpSession {
  id         String   @id @default(uuid())
  phone      String   @unique
  code       String
  expiresAt  DateTime
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("otp_sessions")
}

// ─── CORE TABLES ───────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  phone           String    @unique
  email           String?
  role            Role      @default(PATIENT)
  otpVerifiedAt   DateTime?
  forumPersona    String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  patientProfile  PatientProfile?
  doctor          Doctor?
  forumPosts      ForumPost[]
  forumReplies    ForumReply[]
  notificationLogs NotificationLog[]

  @@map("users")
}

model PatientProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])

  // FIXED: all were non-nullable — backend creates with empty {} which would fail
  fullName         String?
  dob              DateTime? @db.Date
  sex              Sex?
  city             String?
  heightCm         Decimal?  @db.Decimal(5, 1)
  startWeightKg    Decimal?  @db.Decimal(5, 1)
  currentWeightKg  Decimal?  @db.Decimal(5, 1)
  goalWeightKg     Decimal?  @db.Decimal(5, 1)
  treatmentStartDate DateTime?

  assignedDoctorId String?
  assignedDoctor   Doctor?   @relation(fields: [assignedDoctorId], references: [id])

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  medicalHistory   MedicalHistory?
  consultations    Consultation[]
  prescriptions    Prescription[]
  weightLogs       WeightLog[]
  injectionLogs    InjectionLog[]
  sideEffectLogs   SideEffectLog[]
  labResults       LabResult[]
  orders           Order[]
  subscriptions    Subscription[]
  addresses        Address[]
  careTeamAccess   CareTeamAccess[]
  patientFlags     PatientFlag[]
  notificationPrefs NotificationPreference?

  @@map("patient_profiles")
}

model Doctor {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  fullName         String
  qualification    String
  mciNumber        String    @unique
  specialisation   String
  phone            String
  waPhone          String
  isAvailable      Boolean   @default(true)
  ratePerConsult   Int       // in paise
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  patients         PatientProfile[]
  consultations    Consultation[]
  prescriptions    Prescription[]
  availability     DoctorAvailability[]
  earnings         DoctorEarning[]

  @@map("doctors")
}

model MedicalHistory {
  id                   String             @id @default(uuid())
  patientId            String             @unique
  patient              PatientProfile     @relation(fields: [patientId], references: [id])
  conditions           Json
  medications          Json
  allergies            Json
  contraindications    Json
  eligibilityResult    EligibilityResult
  eligibilityCheckedAt DateTime
  confirmedByDoctorId  String?
  confirmedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@map("medical_history")
}

// ─── CONSULTATION ──────────────────────────────────────────────────────────────

model Consultation {
  id                String        @id @default(uuid())
  patientId         String
  patient           PatientProfile @relation(fields: [patientId], references: [id])
  doctorId          String
  doctor            Doctor        @relation(fields: [doctorId], references: [id])
  scheduledAt       DateTime
  // FIXED: was ConsultStatus enum with BOOKED — now SCHEDULED matches backend code
  status            ConsultStatus @default(SCHEDULED)
  razorpayOrderId   String?
  razorpayPaymentId String?
  paymentStatus     PaymentStatus @default(PENDING)
  // FIXED: field was amountPaise — backend was incorrectly using feePaise
  amountPaise       Int
  notes             String?
  doseDecision      DoseDecision?
  nextConsultDate   DateTime?
  labRecommendation String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  prescription      Prescription?

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@map("consultations")
}

model Prescription {
  id             String         @id @default(uuid())
  rxNumber       String         @unique
  patientId      String
  patient        PatientProfile @relation(fields: [patientId], references: [id])
  doctorId       String
  doctor         Doctor         @relation(fields: [doctorId], references: [id])
  consultationId String?        @unique
  consultation   Consultation?  @relation(fields: [consultationId], references: [id])
  medicines      Json
  notes          String?
  pdfS3Key       String?
  validUntil     DateTime       @db.Date
  issuedAt       DateTime       @default(now())

  orders         Order[]

  @@index([patientId])
  @@map("prescriptions")
}

// ─── JOURNEY ───────────────────────────────────────────────────────────────────

model WeightLog {
  id        String         @id @default(uuid())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])
  weightKg  Decimal        @db.Decimal(5, 1)
  waistCm   Decimal?       @db.Decimal(5, 1)
  source    String         @default("app")
  loggedAt  DateTime       @default(now())

  @@index([patientId, loggedAt])
  @@map("weight_logs")
}

model InjectionLog {
  id            String         @id @default(uuid())
  patientId     String
  patient       PatientProfile @relation(fields: [patientId], references: [id])
  medicineName  String
  doseMg        Decimal        @db.Decimal(4, 2)
  injectionSite InjectionSite
  injectedAt    DateTime?
  dueAt         DateTime
  skipped       Boolean        @default(false)
  skipReason    String?
  createdAt     DateTime       @default(now())

  @@index([patientId, dueAt])
  @@map("injection_logs")
}

model SideEffectLog {
  id        String         @id @default(uuid())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])
  symptom   String
  severity  Int
  notes     String?
  loggedAt  DateTime       @default(now())

  @@index([patientId, loggedAt])
  @@map("side_effect_logs")
}

model LabResult {
  id               String         @id @default(uuid())
  patientId        String
  patient          PatientProfile @relation(fields: [patientId], references: [id])
  testName         String
  provider         String
  thyrocareOrderId String?
  results          Json
  reportS3Key      String?
  collectedAt      DateTime
  createdAt        DateTime       @default(now())

  @@index([patientId])
  @@map("lab_results")
}

// ─── ORDERS ────────────────────────────────────────────────────────────────────

model Order {
  id                String         @id @default(uuid())
  orderNumber       String         @unique
  patientId         String
  patient           PatientProfile @relation(fields: [patientId], references: [id])
  prescriptionId    String?
  prescription      Prescription?  @relation(fields: [prescriptionId], references: [id])
  items             Json
  totalAmountPaise  Int
  status            OrderStatus    @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  pharmacyOrderId   String?
  trackingId        String?
  deliveryAddress   Json
  isAutoRefill      Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([patientId])
  @@map("orders")
}

model Subscription {
  id               String             @id @default(uuid())
  patientId        String
  patient          PatientProfile     @relation(fields: [patientId], references: [id])
  medicineName     String
  doseMg           Decimal            @db.Decimal(4, 2)
  frequencyDays    Int                @default(7)
  quantityPerRefill Int
  nextRefillDate   DateTime
  supplyEndsAt     DateTime
  status           SubscriptionStatus @default(ACTIVE)
  razorpaySubId    String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([patientId, nextRefillDate])
  @@map("subscriptions")
}

model Address {
  id        String         @id @default(uuid())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])
  label     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean        @default(false)
  createdAt DateTime       @default(now())

  @@map("addresses")
}

// ─── FORUM ─────────────────────────────────────────────────────────────────────

model ForumPost {
  id               String           @id @default(uuid())
  authorId         String
  author           User             @relation(fields: [authorId], references: [id])
  personaName      String
  title            String
  body             String
  topic            ForumTopic
  isDoctorPost     Boolean          @default(false)
  helpfulCount     Int              @default(0)
  flagCount        Int              @default(0)
  moderationStatus ModerationStatus @default(VISIBLE)
  // ADDED: backend queries isDeleted — added here to match
  isDeleted        Boolean          @default(false)
  isPinned         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  replies          ForumReply[]
  flags            ForumFlag[]

  @@index([topic, createdAt])
  @@index([moderationStatus])
  @@map("forum_posts")
}

model ForumReply {
  id               String           @id @default(uuid())
  postId           String
  post             ForumPost        @relation(fields: [postId], references: [id])
  authorId         String
  author           User             @relation(fields: [authorId], references: [id])
  personaName      String
  body             String
  isDoctorReply    Boolean          @default(false)
  helpfulCount     Int              @default(0)
  moderationStatus ModerationStatus @default(VISIBLE)
  createdAt        DateTime         @default(now())

  @@index([postId, createdAt])
  @@map("forum_replies")
}

model ForumFlag {
  id        String    @id @default(uuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id])
  flaggedBy String
  reason    String
  createdAt DateTime  @default(now())

  @@map("forum_flags")
}

// ─── NOTIFICATIONS ─────────────────────────────────────────────────────────────

model NotificationLog {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id])
  templateName String
  channel      NotificationChannel
  gupshupMsgId String?
  status       NotificationStatus @default(SENT)
  variables    Json
  sentAt       DateTime           @default(now())
  deliveredAt  DateTime?
  readAt       DateTime?

  @@index([userId, sentAt])
  @@index([templateName])
  @@map("notification_logs")
}

model NotificationPreference {
  id                  String         @id @default(uuid())
  patientId           String         @unique
  patient             PatientProfile @relation(fields: [patientId], references: [id])
  whatsappEnabled     Boolean        @default(true)
  emailEnabled        Boolean        @default(true)
  injectionReminder   Boolean        @default(true)
  weightNudge         Boolean        @default(true)
  consultReminder     Boolean        @default(true)
  refillAlert         Boolean        @default(true)
  milestones          Boolean        @default(true)
  weeklySummary       Boolean        @default(true)
  quietHoursStart     Int            @default(22)
  quietHoursEnd       Int            @default(7)
  familyPrivacyMode   Boolean        @default(false)
  updatedAt           DateTime       @updatedAt

  @@map("notification_preferences")
}

// ─── SUPPORT ───────────────────────────────────────────────────────────────────

model PatientFlag {
  id         String         @id @default(uuid())
  patientId  String
  patient    PatientProfile @relation(fields: [patientId], references: [id])
  flagType   String
  severity   String
  data       Json
  resolved   Boolean        @default(false)
  resolvedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([patientId, resolved])
  @@map("patient_flags")
}

model DoctorAvailability {
  id               String  @id @default(uuid())
  doctorId         String
  doctor           Doctor  @relation(fields: [doctorId], references: [id])
  dayOfWeek        Int
  startHour        Int
  endHour          Int
  slotDurationMins Int     @default(30)
  isActive         Boolean @default(true)

  @@map("doctor_availability")
}

model DoctorEarning {
  id             String   @id @default(uuid())
  doctorId       String
  doctor         Doctor   @relation(fields: [doctorId], references: [id])
  consultationId String
  amountPaise    Int
  paidAt         DateTime?
  payoutBatchId  String?
  createdAt      DateTime @default(now())

  @@map("doctor_earnings")
}

model CareTeamAccess {
  id              String         @id @default(uuid())
  patientId       String
  patient         PatientProfile @relation(fields: [patientId], references: [id])
  weightAccess    Boolean        @default(true)
  labAccess       Boolean        @default(true)
  sideEffectAccess Boolean       @default(true)
  habitAccess     Boolean        @default(false)
  updatedAt       DateTime       @updatedAt

  @@map("care_team_access")
}

model ConsentLog {
  id          String   @id @default(uuid())
  userId      String
  consentType String
  version     String
  grantedAt   DateTime @default(now())
  revokedAt   DateTime?
  ipAddress   String?

  @@map("consent_logs")
}
