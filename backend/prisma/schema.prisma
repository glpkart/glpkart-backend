generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum EligibilityResult {
  ELIGIBLE
  INELIGIBLE
}

enum ConsultStatus {
  BOOKED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum DoseDecision {
  CONTINUE
  STEP_UP
  REDUCE
  STOP
}

enum OrderStatus {
  PENDING
  PAID
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum InjectionSite {
  LEFT_ABDOMEN
  RIGHT_ABDOMEN
  LEFT_THIGH
  RIGHT_THIGH
}

enum ForumTopic {
  SIDE_EFFECTS
  FOOD_AND_EATING
  SUCCESS_STORIES
  DOSING_QUESTIONS
  MENTAL_HEALTH
  DOCTOR_ADVICE
  OTHER
}

enum ModerationStatus {
  VISIBLE
  FLAGGED
  REMOVED
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  IN_APP
}

enum NotificationStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

// ─── CORE TABLES ─────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  phone           String    @unique
  email           String?
  role            Role      @default(PATIENT)
  otpVerifiedAt   DateTime?
  forumPersona    String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  patientProfile  PatientProfile?
  doctor          Doctor?
  forumPosts      ForumPost[]
  forumReplies    ForumReply[]
  notificationLogs NotificationLog[]

  @@map("users")
}

model PatientProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  fullName         String
  dob              DateTime  @db.Date
  sex              Sex
  city             String
  heightCm         Decimal   @db.Decimal(5, 1)
  startWeightKg    Decimal   @db.Decimal(5, 1)
  currentWeightKg  Decimal?  @db.Decimal(5, 1)
  goalWeightKg     Decimal?  @db.Decimal(5, 1)
  assignedDoctorId String?
  assignedDoctor   Doctor?   @relation(fields: [assignedDoctorId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  medicalHistory   MedicalHistory?
  consultations    Consultation[]
  prescriptions    Prescription[]
  weightLogs       WeightLog[]
  injectionLogs    InjectionLog[]
  sideEffectLogs   SideEffectLog[]
  labResults       LabResult[]
  orders           Order[]
  subscriptions    Subscription[]
  addresses        Address[]
  careTeamAccess   CareTeamAccess[]
  patientFlags     PatientFlag[]
  notificationPrefs NotificationPreference?

  @@map("patient_profiles")
}

model Doctor {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  fullName         String
  qualification    String
  mciNumber        String    @unique
  specialisation   String
  phone            String
  waPhone          String
  isAvailable      Boolean   @default(true)
  ratePerConsult   Int       // in paise
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  patients         PatientProfile[]
  consultations    Consultation[]
  prescriptions    Prescription[]
  availability     DoctorAvailability[]
  earnings         DoctorEarning[]

  @@map("doctors")
}

model MedicalHistory {
  id                    String            @id @default(uuid())
  patientId             String            @unique
  patient               PatientProfile    @relation(fields: [patientId], references: [id])
  conditions            Json              // { pcos: true, diabetes: false, htn: false, ... }
  medications           Json              // [{ name: "Metformin", dose: "500mg" }]
  allergies             Json              // [{ type: "drug", name: "Penicillin" }]
  contraindications     Json              // { mtc: false, pancreatitis: false, pregnant: false }
  eligibilityResult     EligibilityResult
  eligibilityCheckedAt  DateTime
  confirmedByDoctorId   String?
  confirmedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@map("medical_history")
}

// ─── CONSULTATION ────────────────────────────────────────

model Consultation {
  id                  String        @id @default(uuid())
  patientId           String
  patient             PatientProfile @relation(fields: [patientId], references: [id])
  doctorId            String
  doctor              Doctor        @relation(fields: [doctorId], references: [id])
  scheduledAt         DateTime
  status              ConsultStatus @default(BOOKED)
  razorpayOrderId     String?
  razorpayPaymentId   String?
  paymentStatus       PaymentStatus @default(PENDING)
  amountPaise         Int           // 79900 = ₹799
  notes               String?       // doctor's post-call notes
  doseDecision        DoseDecision?
  nextConsultDate     DateTime?
  labRecommendation   String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  prescription        Prescription?

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@map("consultations")
}

model Prescription {
  id             String         @id @default(uuid())
  rxNumber       String         @unique // SS-RX-20260405-0044
  patientId      String
  patient        PatientProfile @relation(fields: [patientId], references: [id])
  doctorId       String
  doctor         Doctor         @relation(fields: [doctorId], references: [id])
  consultationId String?        @unique
  consultation   Consultation?  @relation(fields: [consultationId], references: [id])
  medicines      Json           // [{ name, dose, frequency, quantity, instructions }]
  notes          String?
  pdfS3Key       String?        // path to signed PDF in S3
  validUntil     DateTime       @db.Date
  issuedAt       DateTime       @default(now())
  // Legal: 7-year retention enforced via DB policy, never hard-deleted

  orders         Order[]

  @@index([patientId])
  @@map("prescriptions")
}

// ─── JOURNEY ─────────────────────────────────────────────

model WeightLog {
  id        String         @id @default(uuid())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])
  weightKg  Decimal        @db.Decimal(5, 1)
  waistCm   Decimal?       @db.Decimal(5, 1)
  source    String         @default("app") // app | whatsapp
  loggedAt  DateTime       @default(now())

  @@index([patientId, loggedAt])
  @@map("weight_logs")
}

model InjectionLog {
  id            String         @id @default(uuid())
  patientId     String
  patient       PatientProfile @relation(fields: [patientId], references: [id])
  medicineName  String
  doseMg        Decimal        @db.Decimal(4, 2)
  injectionSite InjectionSite
  injectedAt    DateTime?      // null if skipped
  dueAt         DateTime
  skipped       Boolean        @default(false)
  skipReason    String?
  createdAt     DateTime       @default(now())

  @@index([patientId, dueAt])
  @@map("injection_logs")
}

model SideEffectLog {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id])
  symptom     String         // nausea, constipation, fatigue, etc.
  severity    Int            // 1-5
  notes       String?
  loggedAt    DateTime       @default(now())

  @@index([patientId, loggedAt])
  @@map("side_effect_logs")
}

model LabResult {
  id               String         @id @default(uuid())
  patientId        String
  patient          PatientProfile @relation(fields: [patientId], references: [id])
  testName         String         // GLP-1 Progress Check
  provider         String         // Thyrocare
  thyrocareOrderId String?
  results          Json           // { hba1c: 6.1, b12: 198, ldl: 128, ... }
  reportS3Key      String?
  collectedAt      DateTime
  createdAt        DateTime       @default(now())

  @@index([patientId])
  @@map("lab_results")
}

// ─── ORDERS ──────────────────────────────────────────────

model Order {
  id               String         @id @default(uuid())
  orderNumber      String         @unique // GK-20260405-0044
  patientId        String
  patient          PatientProfile @relation(fields: [patientId], references: [id])
  prescriptionId   String?
  prescription     Prescription?  @relation(fields: [prescriptionId], references: [id])
  items            Json           // [{ sku, name, qty, pricePaise }]
  totalAmountPaise Int
  status           OrderStatus    @default(PENDING)
  razorpayOrderId  String?
  razorpayPaymentId String?
  pharmacyOrderId  String?        // ID from pharmacy partner
  trackingId       String?        // Delhivery AWB
  deliveryAddress  Json
  isAutoRefill     Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([patientId])
  @@map("orders")
}

model Subscription {
  id              String             @id @default(uuid())
  patientId       String
  patient         PatientProfile     @relation(fields: [patientId], references: [id])
  medicineName    String
  doseMg          Decimal            @db.Decimal(4, 2)
  frequencyDays   Int                @default(7)
  quantityPerRefill Int
  nextRefillDate  DateTime
  supplyEndsAt    DateTime
  status          SubscriptionStatus @default(ACTIVE)
  razorpaySubId   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([patientId, nextRefillDate])
  @@map("subscriptions")
}

model Address {
  id         String         @id @default(uuid())
  patientId  String
  patient    PatientProfile @relation(fields: [patientId], references: [id])
  label      String         // Home, Office
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  isDefault  Boolean        @default(false)
  createdAt  DateTime       @default(now())

  @@map("addresses")
}

// ─── FORUM ───────────────────────────────────────────────

model ForumPost {
  id               String           @id @default(uuid())
  authorId         String
  author           User             @relation(fields: [authorId], references: [id])
  personaName      String           // shown publicly, never real name
  title            String
  body             String
  topic            ForumTopic
  isDoctorPost     Boolean          @default(false)
  helpfulCount     Int              @default(0)
  flagCount        Int              @default(0)
  moderationStatus ModerationStatus @default(VISIBLE)
  isPinned         Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  replies          ForumReply[]
  flags            ForumFlag[]

  @@index([topic, createdAt])
  @@index([moderationStatus])
  @@map("forum_posts")
}

model ForumReply {
  id               String           @id @default(uuid())
  postId           String
  post             ForumPost        @relation(fields: [postId], references: [id])
  authorId         String
  author           User             @relation(fields: [authorId], references: [id])
  personaName      String
  body             String
  isDoctorReply    Boolean          @default(false)
  helpfulCount     Int              @default(0)
  moderationStatus ModerationStatus @default(VISIBLE)
  createdAt        DateTime         @default(now())

  @@index([postId, createdAt])
  @@map("forum_replies")
}

model ForumFlag {
  id        String    @id @default(uuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id])
  flaggedBy String    // user id
  reason    String
  createdAt DateTime  @default(now())

  @@map("forum_flags")
}

// ─── NOTIFICATIONS ───────────────────────────────────────

model NotificationLog {
  id            String              @id @default(uuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  templateName  String
  channel       NotificationChannel
  gupshupMsgId  String?
  status        NotificationStatus  @default(SENT)
  variables     Json                // template variable values used
  sentAt        DateTime            @default(now())
  deliveredAt   DateTime?
  readAt        DateTime?

  @@index([userId, sentAt])
  @@index([templateName])
  @@map("notification_logs")
}

model NotificationPreference {
  id                  String         @id @default(uuid())
  patientId           String         @unique
  patient             PatientProfile @relation(fields: [patientId], references: [id])
  whatsappEnabled     Boolean        @default(true)
  emailEnabled        Boolean        @default(true)
  injectionReminder   Boolean        @default(true)  // cannot be disabled in UI, enforced in API
  weightNudge         Boolean        @default(true)
  consultReminder     Boolean        @default(true)  // cannot be disabled
  refillAlert         Boolean        @default(true)
  milestones          Boolean        @default(true)
  weeklySummary       Boolean        @default(true)
  quietHoursStart     Int            @default(22) // 10 PM
  quietHoursEnd       Int            @default(7)  // 7 AM
  familyPrivacyMode   Boolean        @default(false)
  updatedAt           DateTime       @updatedAt

  @@map("notification_preferences")
}

// ─── SUPPORT ─────────────────────────────────────────────

model PatientFlag {
  id          String         @id @default(uuid())
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id])
  flagType    String         // b12_low, missed_injections, no_weight_log, rapid_loss
  severity    String         // critical | warning
  data        Json           // { value: 108, threshold: 150, unit: 'pg/mL' }
  resolved    Boolean        @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([patientId, resolved])
  @@map("patient_flags")
}

model DoctorAvailability {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  dayOfWeek Int      // 0=Sunday, 6=Saturday
  startHour Int
  endHour   Int
  slotDurationMins Int @default(30)
  isActive  Boolean  @default(true)

  @@map("doctor_availability")
}

model DoctorEarning {
  id             String   @id @default(uuid())
  doctorId       String
  doctor         Doctor   @relation(fields: [doctorId], references: [id])
  consultationId String
  amountPaise    Int      // doctor's share (40000 = ₹400)
  paidAt         DateTime?
  payoutBatchId  String?
  createdAt      DateTime @default(now())

  @@map("doctor_earnings")
}

model CareTeamAccess {
  id              String         @id @default(uuid())
  patientId       String
  patient         PatientProfile @relation(fields: [patientId], references: [id])
  weightAccess    Boolean        @default(true)
  labAccess       Boolean        @default(true)
  sideEffectAccess Boolean       @default(true)
  habitAccess     Boolean        @default(false)
  updatedAt       DateTime       @updatedAt

  @@map("care_team_access")
}

model ConsentLog {
  id          String   @id @default(uuid())
  userId      String
  consentType String   // terms, privacy, data_sharing
  version     String
  grantedAt   DateTime @default(now())
  revokedAt   DateTime?
  ipAddress   String?

  @@map("consent_logs")
}
